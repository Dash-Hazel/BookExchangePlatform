@model BookExchangePlatform.Models.Movie

@* A problem occured duruing production. Check again in case of bugs *@

@Html.AntiForgeryToken()
<h1>Delete Movie</h1>
<h1>Are you certain you would like to delete that movie?</h1>
<div class="card">
    <div class="card-body">
        <h5 class=" card-title">
            @Model.Title
        </h5>
        <h6 class="card-subtitle mb-2 text-muted">
            by @Model.Director
        </h6>
        <p class="card-text">
            Resume: @Model.Resume
        </p>
        <p class="card-text">
            Genre: @Model.Genre
        </p>
        <p class="card-text">
            Release Date: @Model.ReleaseYear.ToString("MMMM dd, yyyy")
        </p>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
