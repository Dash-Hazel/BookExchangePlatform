@model HomeView
@{
    ViewData["Title"] = "Home Page";
}

@if (User.Identity.IsAuthenticated)
{
    <div class="row">
        <div class="col-md-6">
            <h3>Books</h3>
            <p>
                <a asp-controller="Books" asp-action="Create" class="btn btn-primary btn-outline-info">Create a Book</a>
            </p>
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Author</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var book in Model.Books)
                    {
                        <tr>
                            <td>@book.Title</td>
                            <td>@book.Author</td>
                            <td>
                                <a asp-controller="Books" asp-action="Details" asp-route-id="@book.Id" class="btn btn-sm btn-info">Details</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="col-md-6">
            <h3>Movies</h3>
            <p>
                <a asp-controller="Movies" asp-action="Create" class="btn btn-primary btn-outline-info">Create a Movie</a>
            </p>
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Director</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var movie in Model.Movies)
                    {
                        <tr>
                            <td>@movie.Title</td>
                            <td>@movie.Director</td>
                            <td>
                                <a asp-controller="Movies" asp-action="Details" asp-route-id="@movie.Id" class="btn btn-sm btn-info">Details</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="text-center">
    <h1>Welcome to POV</h1>
    <h2>Please, log in or register to gain access to the content.</h2>
    <img src="https://images.unsplash.com/photo-1712402085314-e3449e1d96ef?q=80&w=1546&auto=format&fit=crop"
         alt="Welcome"
         class="img-fluid rounded shadow my-4 mx-auto d-block"
             style="max-height: 400px;" />
    </div>
}